# MongoDB connection string (local MongoDB or Atlas)
MONGODB_URI=mongodb://localhost/reactreadinglist

# Stripe secret key used by the backend /create-payment-intent route
# Use sk_test_... locally/staging and sk_live_... in production.
STRIPE_SECRET_KEY=sk_test_replace_me

# Legacy alias (still supported by server.js for backward compatibility)
# STRIPE_TEST_SECRET_API_KEY=sk_test_replace_me

# Optional: API server port (defaults to 3001)
PORT=3001
